# AWS
AWS_REGION=us-west-2

# GlassBox platform endpoint (Role 3 provides after deploy)
GLASSBOX_API_URL=https://XXX.execute-api.us-west-2.amazonaws.com
GLASSBOX_API_KEY=your-api-key-here

# Bedrock Manager model
BEDROCK_MANAGER_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Guardrails (optional — retrieved from Secrets Manager if not set here)
GUARDRAIL_ID=
GUARDRAIL_VERSION=

# Fallback secrets as env vars (only if Secrets Manager is unavailable)
# GLASSBOX_SECRET_API_GATEWAY_KEY={"key":"..."}
# GLASSBOX_SECRET_BEDROCK_CONFIG={"guardrail_id":"...","guardrail_version":"...","agent_id":"...","agent_alias_id":"..."}
